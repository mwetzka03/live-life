{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Live Life",
  "version": "0.2.0",
  "identifier": "com.mawet.livelife",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Live Life",
        "width": 1280,
        "height": 900,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../scripts/apple_reminders_bridge.py": "scripts/",
      "../scripts/requirements-reminders.txt": "scripts/",
      "../scripts/install-reminders-deps.ps1": "scripts/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Live Life – Gamification des Alltags",
    "longDescription": "Kalender, Challenges, Coins und Shop – alles lokal auf deinem Rechner.",
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  }
}
